POSTGRES_USER=n8n
# Generate securely: openssl rand -base64 32
POSTGRES_PASSWORD=GENERATE_SECURE_PASSWORD_HERE
POSTGRES_DB=n8n
N8N_VERSION=1.89.2

N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/
GENERIC_TIMEZONE=UTC

# Must be a cryptographically secure random string (32+ chars) and identical for main + all workers
# Generate securely: openssl rand -base64 32
N8N_ENCRYPTION_KEY=GENERATE_32_PLUS_CHAR_RANDOM_KEY

# Queue mode settings (required)
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

# Maximum concurrent workflow executions per worker; tune based on CPU/RAM
N8N_CONCURRENCY_PRODUCTION_LIMIT=10

# Observability: structured JSON logs and targeted queue/worker scopes
N8N_LOG_LEVEL=debug
N8N_LOG_OUTPUT=console
N8N_LOG_FORMAT=json
N8N_LOG_SCOPES=scaling,redis,concurrency,waiting-executions,task-runner,task-runner-js,task-runner-py

# Health endpoint path (served as GET /health)
N8N_ENDPOINT_HEALTH=health

# Optional Prometheus metrics endpoint (GET /metrics)
N8N_METRICS=true
N8N_METRICS_PREFIX=n8n_
N8N_METRICS_INCLUDE_API_ENDPOINTS=true
N8N_METRICS_INCLUDE_API_PATH_LABEL=true
N8N_METRICS_INCLUDE_API_METHOD_LABEL=true
N8N_METRICS_INCLUDE_API_STATUS_CODE_LABEL=true
N8N_METRICS_INCLUDE_QUEUE_METRICS=true
N8N_METRICS_INCLUDE_MESSAGE_EVENT_BUS_METRICS=true
