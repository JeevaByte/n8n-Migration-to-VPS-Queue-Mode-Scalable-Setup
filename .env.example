# ─────────────────────────────────────────────────────────────────────────────
# n8n Queue-Mode — Environment Variables Template
# Copy this file to .env and fill in every value marked CHANGE_ME.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── n8n version ───────────────────────────────────────────────────────────────
# Pin to a specific release for reproducible deployments, e.g. 1.40.0
N8N_VERSION=latest

# ── Domain / URL ──────────────────────────────────────────────────────────────
# The public hostname of your n8n instance (no protocol prefix, no trailing slash)
N8N_HOST=n8n.example.com                    # CHANGE_ME

# Full public URL for inbound webhooks (must be reachable by external services)
WEBHOOK_URL=https://n8n.example.com/        # CHANGE_ME

# Full base URL of the n8n editor (usually same as WEBHOOK_URL root)
N8N_EDITOR_BASE_URL=https://n8n.example.com # CHANGE_ME

# ── Encryption key ────────────────────────────────────────────────────────────
# 32-character random string used to encrypt credentials stored in the DB.
# Generate with: openssl rand -hex 32
# WARNING: Changing this after workflows are created will break all credentials.
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_KEY

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
# Maximum memory Redis may use for the queue (increase on high-throughput setups)
REDIS_MAXMEMORY=512mb

# ── Queue mode ────────────────────────────────────────────────────────────────
# Number of simultaneous workflow executions per worker container
N8N_WORKER_CONCURRENCY=10

# Number of worker containers to start (override at runtime with --scale)
N8N_WORKER_REPLICAS=2

# Set to "true" to stop the main process from picking up production executions
# and leave that exclusively to workers.
N8N_DISABLE_PRODUCTION_MAIN_PROCESS=false

# ── Worker resource limits (Docker Compose deploy.resources) ─────────────────
WORKER_CPU_LIMIT=1.0
WORKER_MEM_LIMIT=1G

# ── Execution data retention ──────────────────────────────────────────────────
# Hours to keep execution records (168 = 7 days)
EXECUTIONS_DATA_MAX_AGE=168

# Save execution data for successful runs? ("all" | "none")
# Keeping "none" reduces DB growth significantly in high-volume setups.
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none

# ── Timezone ──────────────────────────────────────────────────────────────────
# IANA timezone name, e.g. America/New_York, Europe/Berlin, Asia/Kolkata
GENERIC_TIMEZONE=UTC

# ── User management / auth ────────────────────────────────────────────────────
N8N_USER_MANAGEMENT_DISABLED=false
N8N_BASIC_AUTH_ACTIVE=false

# ── Optional SMTP (for user-management emails) ────────────────────────────────
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.example.com              # CHANGE_ME or leave blank
N8N_SMTP_PORT=587
N8N_SMTP_USER=noreply@example.com           # CHANGE_ME or leave blank
N8N_SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
N8N_SMTP_SENDER=n8n <noreply@example.com>   # CHANGE_ME or leave blank
